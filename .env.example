# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Database ────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# Omit :<password> if no password is set (e.g. local dev with trust auth).
DATABASE_URL=postgresql+asyncpg://your_user:your_password@localhost:5432/jwt_api_db

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ─────────────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000

# ── Bootstrap admin ─────────────────────────────────────────────────────────
# Seeded on startup ONLY if no admin exists yet. Leave blank to disable.
# Password must be >= 8 chars. Change these before any real deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_8+chars
ADMIN_EMAIL=admin@example.com
